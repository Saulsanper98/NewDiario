# Copia a .env y rellena los valores.
# Secreto para sesiones JWT (Auth.js). Mínimo ~32 caracteres; genera uno con:
#   openssl rand -base64 32
# (AUTH_SECRET es el nombre preferido en Auth.js v5; NEXTAUTH_SECRET sigue admitido.)
AUTH_SECRET=
NEXTAUTH_SECRET=

# URL pública de la app (login/callbacks). En local suele ser http://localhost:3000 o el puerto que use Next.
NEXTAUTH_URL=http://localhost:3000

# PostgreSQL (credenciales del docker-compose: ccops / ccops_password / ccops_db)
# Puerto 5433 en el host = mapeo del compose (evita otro Postgres en 5432). Dentro de Docker la app usa postgres:5432.
DATABASE_URL=postgresql://ccops:ccops_password@127.0.0.1:5433/ccops_db

# Opcional: inicio de sesión con Microsoft Entra ID
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
